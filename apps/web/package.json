{
  "name": "edunexus-web",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "typecheck": "vue-tsc --noEmit",
    "format": "prettier --ignore-path ../../.prettierignore --write . ../../README.md ../../.github/workflows/ci.yml",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "format:check": "prettier --ignore-path ../../.prettierignore --check . ../../README.md ../../.github/workflows/ci.yml",
    "generate:types": "openapi-typescript ../../packages/shared-contracts/openapi/openapi.yaml -o src/types/api.d.ts"
  },
  "dependencies": {
    "axios": "^1.8.2",
    "dompurify": "^3.3.1",
    "echarts": "^6.0.0",
    "lucide-vue-next": "^0.575.0",
    "marked": "^17.0.3",
    "naive-ui": "^2.43.2",
    "pinia": "^2.3.1",
    "vue": "^3.5.13",
    "vue-echarts": "^8.0.1",
    "vue-router": "^4.5.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/dompurify": "^3.0.5",
    "@types/jsdom": "^27.0.0",
    "@types/marked": "^5.0.2",
    "@vitejs/plugin-vue": "^5.2.1",
    "eslint": "^10.0.3",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-vue": "^10.8.0",
    "jsdom": "^27.2.0",
    "openapi-typescript": "^7.13.0",
    "pinia-plugin-persistedstate": "^3.2.3",
    "prettier": "^3.6.2",
    "typescript": "^5.8.2",
    "typescript-eslint": "^8.56.1",
    "vite": "^6.2.0",
    "vitest": "^4.0.0",
    "vue-tsc": "^2.2.12"
  }
}
